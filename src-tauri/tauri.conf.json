{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DeskWidget Beta",
  "version": "1.2.3",
  "mainBinaryName": "DeskWidgetBeta",
  "identifier": "com.coutoapps.deskwidget.beta",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DeskWidget Beta",
        "width": 8,
        "height": 150,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: http://localhost:1420; connect-src 'self' https://zpawkjebkogozdfhqubp.supabase.co https://api.telegram.org https://api.github.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:1420; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: asset: tauri:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "CoutoApps",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "pt-BR"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "installerHooks": "installer-hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
